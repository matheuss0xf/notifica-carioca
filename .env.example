# Server
SERVER_PORT=8080
SHUTDOWN_TIMEOUT=10s
READ_HEADER_TIMEOUT=5s
READ_TIMEOUT=15s
WRITE_TIMEOUT=30s
IDLE_TIMEOUT=60s

# PostgreSQL
DATABASE_URL=postgres://notifica:notifica@localhost:5432/notifica_carioca?sslmode=disable

# Redis
REDIS_PASSWORD=my-redis-password-change-me
REDIS_URL=redis://default:my-redis-password-change-me@localhost:6379/0

# Security — CHANGE THESE IN PRODUCTION
WEBHOOK_SECRET=my-webhook-secret-change-me
CPF_HASH_KEY=my-cpf-hash-key-change-me
JWT_SECRET=my-jwt-secret-change-me
WS_ALLOWED_ORIGINS=

# Cache/Dedup TTLs
IDEMPOTENCY_TTL=24h
UNREAD_CACHE_TTL=1h
