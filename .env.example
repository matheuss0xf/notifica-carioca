# Server
SERVER_PORT=8080
SHUTDOWN_TIMEOUT=10s
READ_HEADER_TIMEOUT=5s
READ_TIMEOUT=15s
WRITE_TIMEOUT=30s
IDLE_TIMEOUT=60s

# PostgreSQL
DATABASE_URL=postgres://notifica:notifica@localhost:5432/notifica_carioca?sslmode=disable
DOCKER_DATABASE_URL=postgres://notifica:notifica@postgres:5432/notifica_carioca?sslmode=disable

# Redis
REDIS_PASSWORD=dev-redis-secret
REDIS_URL=redis://default:dev-redis-secret@localhost:6379/0

# Security - development only
WEBHOOK_SECRET=dev-webhook-secret
CPF_HASH_KEY=dev-cpf-hash-key
JWT_SECRET=dev-jwt-secret
WS_ALLOWED_ORIGINS=
ENABLE_HSTS=false
HSTS_MAX_AGE_SECONDS=31536000

# Rate limiting - relaxed for local load tests
RATE_LIMIT_WINDOW=1m
WEBHOOK_RATE_LIMIT=5000
NOTIFICATIONS_RATE_LIMIT=5000
WEBSOCKET_RATE_LIMIT=1000

# Cache / dedup
IDEMPOTENCY_TTL=24h
UNREAD_CACHE_TTL=1h
WEBHOOK_DLQ_KEY=webhook:dlq
WEBHOOK_DLQ_MAX_LEN=1000
