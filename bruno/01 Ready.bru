meta {
  name: Ready
  type: http
  seq: 3
}

get {
  url: {{baseUrl}}/ready
  body: none
  auth: none
}

script:post-response {
  const body = res.getBody();

  if (!body || (body.status !== "ready" && body.status !== "not_ready")) {
    throw new Error("Readiness check returned an unexpected payload");
  }
}
